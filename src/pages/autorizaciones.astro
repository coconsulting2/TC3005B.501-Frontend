---
/**
 * Author: Diego Ortega Fernandez
 * Updated: Editorial Finance design system
 * Updated (M2-007): Emiliano Deyta Illescas
 *   — wraps the inbox in ApprovalsInbox so N1 / N2 can filter
 *     pending requests by date, monto and tipo before drilling
 *     into the detail page.
 */

import MainLayout from "@layouts/MainLayout.astro";
import EditorialHeader from "@components/EditorialHeader.astro";
import ApprovalsInbox from "@components/ApprovalsInbox";
import TableFallback from "@/components/Table/TableFallback.astro";

import type { UserRole } from "@type/roles";
import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import { apiRequest } from "@/utils/apiClient";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const userName = getCookie("username", Astro.cookies);
const buttonLabel = roleLabels[role];

/** BD: 2 = Primera Revisión (pendiente N1), 3 = Segunda Revisión (pendiente N2). */
const status = getCookie("role", Astro.cookies) === "N1" ? 2 : 3;
const requests = await (async () => {
  try {
    return await apiRequest(`/user/get-travel-requests/${getCookie("department_id", Astro.cookies)}/${status}`, { cookies: Astro.cookies });
  } catch (error) {
    return [];
  }
})();
---

<MainLayout title="Bandeja de aprobaciones" data={{ userName, buttonLabel, role }}>
  <div>
    {requests && requests.length === 0 ? (
      <TableFallback />
    ) : (
      <>
        <EditorialHeader
          eyebrow="Coco / Aprobaciones"
          title={`Bandeja de ${userName}`}
          subtitle="Solicitudes pendientes de autorizar"
        />
        <ApprovalsInbox
          client:only="react"
          data={requests}
          role={role}
        />
      </>
    )}
  </div>
</MainLayout>
