---
/**
 * /admin/mapeo-gastos — Asocia cada ReceiptType (Avión, Hotel, ...) a una
 * cuenta de cargo y una de abono del catálogo contable (M3-007).
 * Integración con API real al liberar /admin/expense-mappings en backend.
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MainLayout from "@layouts/MainLayout.astro";
import ExpenseTypeMappingAdmin from "@components/ExpenseTypeMappingAdmin";
import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import type { UserRole } from "@type/roles";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const buttonLabel = roleLabels[role];
const userName = getCookie("username", Astro.cookies);
const token = getCookie("token", Astro.cookies);
---

<MainLayout title="Mapeo de gastos" data={{ userName, buttonLabel, role }}>
  <div>
    <EditorialHeader
      eyebrow="Coco / Administración / Mapeo de gastos"
      title="Mapeo de tipos de gasto"
      subtitle="Define qué cuenta contable se mueve al registrar y al pagar cada tipo de comprobante."
    />
    <ExpenseTypeMappingAdmin client:only="react" token={token} />
  </div>
</MainLayout>
