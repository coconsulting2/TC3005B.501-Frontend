---
/**
 * /admin/workflow-simulator — Herramienta de simulación de flujo de
 * aprobación para admin (M2-008). Llama a POST /workflow/simulate y cae
 * a reglas locales mientras el backend está en desarrollo.
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MainLayout from "@layouts/MainLayout.astro";
import SimuladorWorkflow from "@components/SimuladorWorkflow";
import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import type { UserRole } from "@type/roles";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const buttonLabel = roleLabels[role];
const userName = getCookie("username", Astro.cookies);
const token = getCookie("token", Astro.cookies);
---

<MainLayout title="Simulador de flujo" data={{ userName, buttonLabel, role }}>
  <div>
    <EditorialHeader
      eyebrow="Coco / Administración / Simulador"
      title="Simulador de flujo de aprobación"
      subtitle="Prueba un importe y visualiza la ruta de niveles antes de activar cambios en la política."
    />
    <SimuladorWorkflow client:only="react" token={token} />
  </div>
</MainLayout>
