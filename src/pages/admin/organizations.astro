---
/**
 * /admin/organizations — listado, creación y edición de organizaciones (tenants).
 * Solo visible para super-admin Ditta (gated por permiso organization:list_all).
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MainLayout from "@layouts/MainLayout.astro";
import OrganizationsAdmin from "@views/admin/OrganizationsAdmin";
import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import type { UserRole } from "@type/roles";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const buttonLabel = roleLabels[role];
const userName = getCookie("username", Astro.cookies);
const token = getCookie("token", Astro.cookies);
---

<MainLayout title="Organizaciones" data={{ userName, buttonLabel, role }}>
  <div>
    <EditorialHeader
      eyebrow="Coco / Administración / Organizaciones"
      title="Organizaciones"
      subtitle="Da de alta nuevas organizaciones cliente, configura su estado y gestiona el aislamiento de datos."
    />
    <OrganizationsAdmin client:only="react" token={token} />
  </div>
</MainLayout>
