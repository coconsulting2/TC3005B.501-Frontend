---
/**
 * /admin/api-keys — Generar, nombrar y revocar llaves API para integraciones ERP.
 * Requiere permiso `api_key:manage`.
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MainLayout from "@layouts/MainLayout.astro";
import ApiKeysManager from "@views/admin/ApiKeysManager";
import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import type { UserRole } from "@type/roles";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const buttonLabel = roleLabels[role];
const userName = getCookie("username", Astro.cookies);
const token = getCookie("token", Astro.cookies);
---

<MainLayout title="Llaves API" data={{ userName, buttonLabel, role }}>
  <div>
    <EditorialHeader
      eyebrow="Coco / Administración / Integraciones"
      title="Llaves API"
      subtitle="Genera credenciales para que sistemas ERP consuman la exportación contable sin usuario y contraseña humanos."
    />
    <ApiKeysManager client:only="react" token={token} />
  </div>
</MainLayout>
