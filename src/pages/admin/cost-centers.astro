---
/**
 * /admin/cost-centers — CRUD de centros de costos con jerarquía.
 * NT-020. Integración con API real al liberar M3-005.
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MainLayout from "@layouts/MainLayout.astro";
import CostCenterAdmin from "@components/CostCenterAdmin";
import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import type { UserRole } from "@type/roles";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const buttonLabel = roleLabels[role];
const userName = getCookie("username", Astro.cookies);
const token = getCookie("token", Astro.cookies);
---

<MainLayout title="Centros de Costos" data={{ userName, buttonLabel, role }}>
  <div>
    <EditorialHeader
      eyebrow="Coco / Administración / Centros de costos"
      title="Centros de costos"
      subtitle="Estructura jerárquica para imputación contable de gastos."
    />
    <CostCenterAdmin client:only="react" token={token} />
  </div>
</MainLayout>
