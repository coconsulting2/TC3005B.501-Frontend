---
/**
 * /admin/catalogo-contable — CRUD de cuentas contables del catálogo
 * por organización (M3-007). Integración con API real al liberar
 * /admin/accounting-accounts en backend.
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MainLayout from "@layouts/MainLayout.astro";
import AccountingAccountAdmin from "@components/AccountingAccountAdmin";
import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import type { UserRole } from "@type/roles";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const buttonLabel = roleLabels[role];
const userName = getCookie("username", Astro.cookies);
const token = getCookie("token", Astro.cookies);
---

<MainLayout title="Catálogo contable" data={{ userName, buttonLabel, role }}>
  <div>
    <EditorialHeader
      eyebrow="Coco / Administración / Catálogo contable"
      title="Catálogo de cuentas contables"
      subtitle="Registra y mantiene las cuentas de cargo y abono utilizadas por la organización."
    />
    <AccountingAccountAdmin client:only="react" token={token} />
  </div>
</MainLayout>
