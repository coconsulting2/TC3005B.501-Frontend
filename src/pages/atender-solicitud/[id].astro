---
/**
 * Author: Eduardo Porto Morales
 * 
 */
export const prerender = false;

import MainLayout from "@layouts/MainLayout.astro";
import RequestDetail from "@components/RequestDetail.astro";
import AproveRequest from "@components/AproveRequestModal";
import AttendRequest from "@components/AttendRequest";
import type { UserRole } from "@type/roles";

import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const userName = getCookie("username", Astro.cookies);
const buttonLabel = roleLabels[role];
const token = getCookie("token", Astro.cookies);
const userId = getCookie("id", Astro.cookies);

import { apiRequest } from "@/utils/apiClient";
import {
  buildHotelSearchDefaults,
  computeAgencyServiceFlags,
} from "@/utils/travelRequestAgency";

const { id } = Astro.params;
let request = null;
try {
  request = await apiRequest(`/applicant/get-user-request/${id}`, { cookies: Astro.cookies });
} catch (error) {
  request = null;
  throw new Error(`No request found with ID ${id}`);
  return Astro.redirect('/404');
}

const { needsPlane, needsHotel } = computeAgencyServiceFlags(request.routes);
const hotelSearchDefaults = buildHotelSearchDefaults(request.routes);
const needsAgencyQuotation = needsPlane || needsHotel;

---

<MainLayout title={`Solicitud #${request.request_id}`} data={{ userName, buttonLabel, role }} >
  <RequestDetail
    request={request}
    title={`SOLICITUD #${request.request_id}`}
    subtitle="Detalles de la Solicitud a Atender"
    currentUserId={userId ? parseInt(String(userId), 10) : undefined}
    authToken={token}
  />
  {needsAgencyQuotation ? (
    <div class="mt-8">
      <AttendRequest
        client:only="react"
        request_id={String(request.request_id)}
        token={token}
        needsPlane={needsPlane}
        needsHotel={needsHotel}
        hotelSearchDefaults={hotelSearchDefaults}
      />
    </div>
  ) : (
    <div class="flex justify-end gap-4 mt-8">
      <AproveRequest
        client:only="react"
        request_id={request.request_id}
        title="Finalizar atención"
        message="¿Marcar esta solicitud como atendida por agencia? (sin vuelo requerido en la solicitud)"
        redirection="/dashboard"
        modal_type="success"
        variant="filled"
        token={token}
      >
        Finalizar atención
      </AproveRequest>
    </div>
  )}
</MainLayout>
