---
/**
 * Author: Eduardo Porto Morales
 * 
 */
export const prerender = false;

import MainLayout from "@layouts/MainLayout.astro";
import RequestDetail from "@components/RequestDetail.astro";
import AproveRequest from "@components/AproveRequestModal";
import AttendRequest from "@components/AttendRequest";
import type { UserRole } from "@type/roles";

import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const userName = getCookie("username", Astro.cookies);
const buttonLabel = roleLabels[role];
const token = getCookie("token", Astro.cookies);
const userId = getCookie("id", Astro.cookies);

import { apiRequest } from "@/utils/apiClient";
import {
  buildFlightSegmentsForQuote,
  buildHotelSearchDefaults,
  computeAgencyServiceFlags,
} from "@/utils/travelRequestAgency";

const { id } = Astro.params;
let request = null;
try {
  request = await apiRequest(`/applicant/get-user-request/${id}`, { cookies: Astro.cookies });
} catch (error) {
  request = null;
  throw new Error(`No request found with ID ${id}`);
  return Astro.redirect('/404');
}

const { needsPlane, needsHotel } = computeAgencyServiceFlags(request.routes);
const hotelSearchDefaults = buildHotelSearchDefaults(request.routes);
const flightSegments = buildFlightSegmentsForQuote(request.routes);
const needsAgencyQuotation = needsPlane || needsHotel;
const isCancelled = Number(request.request_status_id) === 9;

---

<MainLayout title={`Solicitud #${request.request_id}`} data={{ userName, buttonLabel, role }} >
  <RequestDetail
    request={request}
    title={`SOLICITUD #${request.request_id}`}
    subtitle={isCancelled ? "Viaje cancelado por el solicitante" : "Detalles de la Solicitud a Atender"}
    currentUserId={userId ? parseInt(String(userId), 10) : undefined}
    authToken={token}
  />

  {isCancelled && (
    <section class="card-editorial border-danger-200 bg-danger-50 p-5 sm:p-6 mt-8" role="alert">
      <p class="eyebrow text-danger-600">Cancelación</p>
      <h2 class="font-editorial text-xl font-normal text-[var(--color-ink)] mt-1">
        Este viaje fue cancelado
      </h2>
      <p class="text-sm text-[var(--color-ink-secondary)] mt-2">
        El solicitante canceló después de que la agencia registró la reserva. No puedes modificar la cotización.
      </p>
      {(request.selected_flight_offer || request.selected_hotel_offer) && (
        <ul class="mt-4 space-y-2 text-sm text-[var(--color-ink)]">
          {request.selected_flight_offer && (
            <li>
              <span class="font-medium">Vuelo:</span>{" "}
              {typeof request.selected_flight_offer === "object" && request.selected_flight_offer !== null
                ? (request.selected_flight_offer as { label?: string }).label ?? "Reserva registrada"
                : "Reserva registrada"}
            </li>
          )}
          {request.selected_hotel_offer && (
            <li>
              <span class="font-medium">Hotel:</span>{" "}
              {typeof request.selected_hotel_offer === "object" && request.selected_hotel_offer !== null
                ? (request.selected_hotel_offer as { label?: string }).label ?? "Reserva registrada"
                : "Reserva registrada"}
            </li>
          )}
        </ul>
      )}
    </section>
  )}

  {!isCancelled && needsAgencyQuotation ? (
    <div class="mt-8">
      <AttendRequest
        client:only="react"
        request_id={String(request.request_id)}
        token={token}
        needsPlane={needsPlane}
        needsHotel={needsHotel}
        hotelSearchDefaults={hotelSearchDefaults}
        flightSegments={flightSegments}
        initialFlightOffer={request.selected_flight_offer}
      />
    </div>
  ) : !isCancelled ? (
    <div class="flex justify-end gap-4 mt-8">
      <AproveRequest
        client:only="react"
        request_id={request.request_id}
        title="Finalizar atención"
        message="¿Marcar esta solicitud como atendida por agencia? (sin vuelo requerido en la solicitud)"
        redirection="/dashboard"
        modal_type="success"
        variant="filled"
        token={token}
      >
        Finalizar atención
      </AproveRequest>
    </div>
  ) : null}
</MainLayout>
