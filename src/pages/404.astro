---
import Layout from "@layouts/Layout.astro";
const token = Astro.cookies.get("token")?.value;
const isAuthenticated = !!token;
---

<Layout title="Página no encontrada">
  <main class="min-h-screen flex flex-col" style="background-color: var(--color-ink, #0A0A0A);">
    <div class="flex-grow flex flex-col justify-center items-center text-center max-w-lg mx-auto px-6">
      <img
        src="/Logo.svg"
        alt="CocoAPI"
        width="48"
        height="48"
        class="mb-8 opacity-40"
      />
      <h1 class="font-editorial text-5xl font-light text-[var(--color-surface,#FAFAF7)] flex gap-3 items-baseline">
        <span class="text-accent-400">404</span>
        <span class="text-[var(--color-surface,#FAFAF7)]/60 font-light">No encontrado</span>
      </h1>
      <p class="mt-4 text-[var(--color-surface,#FAFAF7)]/50 text-sm leading-relaxed">
        La página que buscas no existe o no tienes permiso para acceder.
      </p>
      <p class="mt-6 px-4 py-2 text-xs font-mono text-[var(--color-surface,#FAFAF7)]/30 border border-[var(--color-surface,#FAFAF7)]/10 rounded-[var(--radius-md,6px)]">
        {Astro.url.pathname}
      </p>
    </div>

    <div class="flex justify-center mb-24">
      <a
        href={isAuthenticated ? "/dashboard" : "/login"}
        class="px-6 py-2.5 text-sm font-medium text-white rounded-[var(--radius-md,6px)] transition-colors"
        style="background-color: var(--color-primary-500, #3D4A2A);"
      >
        {isAuthenticated ? "Ir al dashboard" : "Ir al login"}
      </a>
    </div>
  </main>
</Layout>
