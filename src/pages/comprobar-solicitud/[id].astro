---
/**
* Authors: Gabriel Munoz Luna
* Updated: Editorial Finance design system
**/
export const prerender = false;

import MainLayout from "@layouts/MainLayout.astro";
import EditorialHeader from "@components/EditorialHeader.astro";
import AstroButton from "@components/Button.astro";
import Button from "@components/Button.tsx";
import { getCookie } from "@data/cookies";
import ValidateReceiptStatus from "@components/ValidateReceiptStatus.tsx";

const userName = getCookie("username", Astro.cookies);
const role = getCookie("role", Astro.cookies);
const buttonLabel = role;

import { apiRequest } from "@/utils/apiClient";

const { id } = Astro.params;
let request = null;
try {
  request = await apiRequest(`/accounts-payable/get-expense-validations/${id}`, { cookies: Astro.cookies });
} catch (error) {
  request = null;
  throw new Error(`No request found with ID ${id}`);
  return Astro.redirect('/404');
}

const StateColors: Record<string, string> = {
  'Aprobado': 'status-pill--approved',
  'Rechazado': 'status-pill--rejected',
  'Pendiente': 'status-pill--pending',
};
---

<MainLayout title={`Comprobantes de la solicitud #${id}`} data={{ userName, role, buttonLabel }}>
  <main>
    <EditorialHeader
      eyebrow={`Coco / Comprobantes / #${id}`}
      title={`Comprobantes de la solicitud #${id}`}
      subtitle="Comprobantes de gasto asociados"
    >
      <a href={`/subir-comprobante/${id}`}>
        <AstroButton variant="filled" color="primary">
          + Agregar comprobante
        </AstroButton>
      </a>
    </EditorialHeader>

    <section class="card-editorial overflow-hidden">
      {request.Expenses.length > 0 ? (
        <div>
          {request.Expenses.map((expense: any, index: number) => {
            const isLast = index === request.Expenses.length - 1;
            return (
              <div class={`px-6 py-5 flex items-center justify-between gap-4 ${!isLast ? 'border-b border-[var(--color-neutral-200)]' : ''}`}>
                <div class="flex items-center gap-4 flex-1 min-w-0">
                  <span class="font-editorial text-lg text-[var(--color-ink-muted)] tabular-nums w-6 text-right">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div>
                    <p class="font-medium text-[var(--color-ink)]">{expense.receipt_type_name}</p>
                    <p class="text-xs text-[var(--color-ink-muted)] mt-0.5">ID: {expense.receipt_id}</p>
                  </div>
                </div>

                <span class="money-display text-lg text-[var(--color-ink)]">${expense.amount}</span>

                <div class="flex items-center gap-3">
                  <span class={`status-pill ${StateColors[expense.validation] || 'status-pill--review'}`}>
                    {expense.validation}
                  </span>
                  {expense.validation === 'Rechazado' && (
                    <a href={`/resubir-comprobante/${id}?replace=${expense.receipt_id}`}>
                      <AstroButton variant="border" color="accent">
                        Resubir
                      </AstroButton>
                    </a>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="p-8 text-center">
          <p class="text-sm text-[var(--color-ink-muted)]">
            Aún no has subido comprobantes para esta solicitud.
          </p>
        </div>
      )}
    </section>
  </main>

  <div class="fixed bottom-6 right-6 z-50">
    <ValidateReceiptStatus
      client:only="react"
      request_id={id}
      title="Confirmar envío"
      message="¿Está seguro de que desea mandar estos comprobantes?"
      redirection="/dashboard"
      modal_type="success"
      variant="filled"
      token={getCookie("token", Astro.cookies)}
    >
      Mandar a validar
    </ValidateReceiptStatus>
  </div>
</MainLayout>
