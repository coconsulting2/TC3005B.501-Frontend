---
/**
* Authors: Gabriel Munoz Luna
* Updated: Editorial Finance design system
**/
export const prerender = false;

import MainLayout from "@layouts/MainLayout.astro";
import EditorialHeader from "@components/EditorialHeader.astro";
import AstroButton from "@components/Button.astro";
import ReceiptDetailCard from "@components/ReceiptDetailCard";
import { getCookie } from "@data/cookies";
import type { UserRole } from "@type/roles";
import ValidateReceiptStatus from "@components/ValidateReceiptStatus.tsx";
import ResumenTramos from "@components/ResumenTramos";

const userName = getCookie("username", Astro.cookies);
const role = getCookie("role", Astro.cookies) as UserRole;
const buttonLabel = role;
const token = getCookie("token", Astro.cookies) ?? "";

import { apiRequest } from "@/utils/apiClient";
import { requestAllowsReceiptUpload } from "@utils/receiptUploadAccess";

const { id } = Astro.params;
/** Datos de GET /accounts-payable/get-expense-validations/:id */
let request: {
  request_status_id?: number;
  request_status_name?: string;
  Expenses: Array<Record<string, unknown>>;
} | null = null;
let comprobantesError: string | null = null;
try {
  request = await apiRequest(`/accounts-payable/get-expense-validations/${id}`, { cookies: Astro.cookies });
} catch (e: unknown) {
  const detail = e && typeof e === "object" && "detail" in e ? (e as { detail?: { status?: number } }).detail : undefined;
  const st = detail?.status;
  if (st === 404) {
    return Astro.redirect("/404");
  }
  if (st === 401) {
    return Astro.redirect("/login");
  }
  comprobantesError =
    st === 403
      ? "Tu usuario no tiene permiso para ver esta vista de comprobantes. Si eres Cuentas por pagar, recarga la app tras actualizar; si el problema continúa, vuelve al listado de comprobaciones."
      : "No se pudo cargar el detalle (error al consultar el servidor). Vuelve al listado e inténtalo de nuevo.";
  request = null;
}

const requestStatusId = request ? Number(request.request_status_id) : NaN;
/** Solo en estado 6 (Comprobación gastos del viaje) se puede enviar a validación (PUT send-expense-validation). */
const canSendForValidation = requestStatusId === 6;
/** En 7 ya se envió a CxP: el botón no aplica; mostramos confirmación, no un “fallo” de UI. */
const alreadySentToAccountsPayable = requestStatusId === 7;
const canUploadReceipts = request ? requestAllowsReceiptUpload(request.request_status_id) : false;
const listHref = role === "Cuentas por pagar" ? "/comprobaciones" : "/comprobar-gastos";

// Enrich expenses with file metadata (same as comprobar-gastos)
const enrichedExpenses = request ? await Promise.all(
  request.Expenses.map(async (receipt: any) => {
    try {
      const fileMap = await apiRequest(`/files/receipt-files/${receipt.receipt_id}`, { cookies: Astro.cookies });
      return { ...receipt, fileMap };
    } catch {
      return { ...receipt, fileMap: null };
    }
  })
) : [];
---

<MainLayout title={`Comprobantes de la solicitud #${id}`} data={{ userName, role, buttonLabel }}>
  {comprobantesError ? (
    <main class="p-6 max-w-lg mx-auto">
      <p class="text-sm text-[var(--color-ink)] mb-4">{comprobantesError}</p>
      <a
        href={listHref}
        class="text-sm font-medium text-primary-500 hover:text-primary-600 underline"
      >
        Volver al listado de comprobantes
      </a>
    </main>
  ) : (
  <>
  <main>
    <EditorialHeader
      eyebrow={`Coco / Comprobantes / #${id}`}
      title={`Comprobantes de la solicitud #${id}`}
      subtitle="Comprobantes de gasto asociados"
    >
      {canUploadReceipts ? (
        <a href={`/subir-comprobante/${id}`}>
          <AstroButton variant="filled" color="primary">
            + Agregar comprobante
          </AstroButton>
        </a>
      ) : (
        <p class="text-xs text-[var(--color-ink-muted)] max-w-md text-right">
          Los comprobantes se pueden agregar cuando la solicitud vaya en <strong>Cotización del Viaje</strong> o fases posteriores (tras aprobación N2).
        </p>
      )}
    </EditorialHeader>

    <section class="card-editorial overflow-hidden">
      {enrichedExpenses.length > 0 ? (
        <div>
          {enrichedExpenses.map((expense: any, index: number) => {
            const isLast = index === enrichedExpenses.length - 1;
            return (
              <ReceiptDetailCard
                client:visible
                index={index}
                receiptId={expense.receipt_id}
                receiptTypeName={expense.receipt_type_name}
                amount={expense.amount}
                validation={expense.validation}
                cfdi={expense.cfdi ?? null}
                pdf={expense.fileMap?.pdf ?? null}
                xml={expense.fileMap?.xml ?? null}
                receiptImage={expense.fileMap?.receipt_image ?? null}
                apiBaseUrl={import.meta.env.PUBLIC_API_BASE_URL}
                isLast={isLast}
              >
                {expense.validation === 'Rechazado' && canUploadReceipts && (
                  <div class="mt-3 ml-10 flex items-center gap-3">
                    <a href={`/resubir-comprobante/${id}?replace=${expense.receipt_id}`}>
                      <AstroButton variant="border" color="accent">
                        Resubir
                      </AstroButton>
                    </a>
                  </div>
                )}
              </ReceiptDetailCard>
            );
          })}
        </div>
      ) : (
        <div class="p-8 text-center">
          <p class="text-sm text-[var(--color-ink-muted)]">
            Aún no has subido comprobantes para esta solicitud.
          </p>
        </div>
      )}
    </section>

    <section class="card-editorial p-5 sm:p-8 mt-6">
      <ResumenTramos
        client:only="react"
        requestId={Number(id)}
        token={token}
      />
    </section>
  </main>

  <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-2 max-w-3/12">
    {alreadySentToAccountsPayable && (
      <div
        class="text-xs text-right bg-[var(--color-surface-white)] border border-success-200 rounded-[var(--radius-md)] px-3 py-2 shadow-sm"
        role="status"
      >
        <p class="text-[var(--color-ink)] font-medium">Comprobantes en validación</p>
        <p class="text-[var(--color-ink-muted)] mt-1">
          Ya enviaste los comprobantes a cuentas por pagar. No hace falta volver a <strong class="text-[var(--color-ink)]">Mandar a validar</strong>.
        </p>
      </div>
    )}
    {!alreadySentToAccountsPayable && !canSendForValidation && requestStatusId > 7 && (
      <p class="text-xs text-[var(--color-ink-muted)] text-right bg-[var(--color-surface-white)] border border-[var(--color-neutral-200)] rounded-[var(--radius-md)] px-3 py-2 shadow-sm">
        La solicitud ya avanzó de fase; mandar a validar no aplica
        {request?.request_status_name && (
          <><br>Estado actual: <strong>{request.request_status_name}</strong></>
        )}
      </p>
    )}
    {!alreadySentToAccountsPayable && !canSendForValidation && requestStatusId < 6 && (
      <p class="text-xs text-[var(--color-ink-muted)] text-right bg-[var(--color-surface-white)] border border-[var(--color-neutral-200)] rounded-[var(--radius-md)] px-3 py-2 shadow-sm">
        Solo puedes mandar a validar cuando la solicitud está en <strong>Comprobación gastos del viaje</strong>
        {request?.request_status_name && (
          <><br>Estado actual: <strong>{request.request_status_name}</strong></>
        )}
      </p>
    )}
    {!alreadySentToAccountsPayable && (canSendForValidation || requestStatusId < 6) && (
      <ValidateReceiptStatus
        client:only="react"
        request_id={Number(id)}
        title="Confirmar envío"
        message="¿Está seguro de que desea mandar estos comprobantes?"
        redirection="/dashboard"
        modal_type="success"
        variant="filled"
        disabled={!canSendForValidation}
        token={getCookie("token", Astro.cookies)}
      >
        Mandar para validación
      </ValidateReceiptStatus>
    )}
  </div>
  </>
  )}
</MainLayout>
