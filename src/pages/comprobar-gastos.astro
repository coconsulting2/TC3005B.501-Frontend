---
/**
* Authors: Eduardo Porto Morales
* Updated: Editorial Finance design system
**/

import MainLayout from "@layouts/MainLayout.astro";
import EditorialHeader from "@components/EditorialHeader.astro";
import MetricCard from "@components/MetricCard.astro";
import type { UserRole } from "@type/roles";

import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import { apiRequest } from '@utils/apiClient';

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const userName = getCookie("username", Astro.cookies);
const buttonLabel = roleLabels[role];
const user_id = getCookie("id", Astro.cookies);

function getVerificationStats(request: any) {
  const verifications = Array.isArray(request.verifications) ? request.verifications : [];
  const total = verifications.length;
  const accepted = verifications.filter((v: any) => v.validation === 'Aprobado').length;
  const rejected = verifications.filter((v: any) => v.validation === 'Rechazado').length;
  const pending = verifications.filter((v: any) => v.validation === 'Pendiente').length;
  return { total, accepted, rejected, pending };
}

const requestsRaw = await (async () => {
  try {
    const requests = await apiRequest(`/applicant/get-user-requests/${user_id}`, { cookies: Astro.cookies });
    return Array.isArray(requests)
      ? requests.filter((request: any) => request.status === 'Comprobación gastos del viaje')
      : [];
  } catch (error) {
    return [];
  }
})();

const requests = await Promise.all(
  requestsRaw.map(async (request: any) => {
    try {
      const { Expenses } = await apiRequest(`/accounts-payable/get-expense-validations/${request.request_id}`, { cookies: Astro.cookies });
      return { ...request, verifications: Expenses ?? [] };
    } catch (e) {
      console.error(`Error al cargar verificaciones de ${request.request_id}`, e);
      return { ...request, verifications: [] };
    }
  })
);
---

<MainLayout title="Comprobaciones" data={{ userName, buttonLabel, role }}>
  <div>
    <main>
      <EditorialHeader
        eyebrow="Coco / Comprobaciones"
        title="Comprobaciones pendientes"
        subtitle={`${userName} — Solicitudes en proceso de comprobación`}
      />

      <div class="flex mb-8">
        <MetricCard
          label="Solicitudes"
          value={String(requests.length)}
          position="solo"
        />
      </div>

      {requests.length > 0 ? (
        <section class="card-editorial overflow-hidden">
          {requests.map((request: any, index: number) => {
            const { total, accepted, rejected, pending } = getVerificationStats(request);
            const percent = (count: number) => total ? (count / total) * 100 : 0;
            const isLast = index === requests.length - 1;

            let statusText = 'Pendiente';
            let statusClass = 'status-pill--pending';
            if (total > 0) {
              if (accepted === total) { statusText = 'Aceptada'; statusClass = 'status-pill--approved'; }
              else if (rejected === total) { statusText = 'Rechazada'; statusClass = 'status-pill--rejected'; }
              else if (pending === 0) { statusText = 'Mixta'; statusClass = 'status-pill--review'; }
            }

            return (
              <a href={`/comprobar-solicitud/${request.request_id}`}
                class={`block px-6 py-5 ${!isLast ? 'border-b border-[var(--color-neutral-200)]' : ''} hover:bg-[var(--color-surface-secondary)] transition-colors`}>
                <div class="flex items-center justify-between gap-4 mb-2">
                  <div class="flex items-center gap-3">
                    <span class="font-editorial text-lg text-[var(--color-ink)] tabular-nums">#{request.request_id}</span>
                    <span class="text-sm text-[var(--color-ink-secondary)]">{request.destination_country}</span>
                  </div>
                  <div class="flex items-center gap-3">
                    {total > 0 && (
                      <span class="text-xs text-[var(--color-ink-muted)] tabular-nums">{accepted}/{total} aceptadas</span>
                    )}
                    <span class={`status-pill ${statusClass}`}>{statusText}</span>
                  </div>
                </div>

                {total > 0 && (
                  <div class="w-full h-1.5 bg-[var(--color-neutral-200)] rounded-full overflow-hidden flex">
                    <div class="bg-success-400 h-full transition-all" style={`width: ${percent(accepted)}%`} />
                    <div class="bg-accent-400 h-full transition-all" style={`width: ${percent(rejected)}%`} />
                    <div class="bg-warning-300 h-full transition-all" style={`width: ${percent(pending)}%`} />
                  </div>
                )}

                <div class="flex gap-4 mt-2 text-xs text-[var(--color-ink-muted)]">
                  <span>{request.beginning_date} — {request.ending_date}</span>
                </div>
              </a>
            );
          })}
        </section>
      ) : (
        <div class="card-editorial py-16 text-center">
          <p class="text-[var(--color-ink-muted)]">No tienes comprobaciones pendientes</p>
        </div>
      )}
    </main>
  </div>
</MainLayout>
