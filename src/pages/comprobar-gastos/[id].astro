---
/**
 * Author: José Antonio González and Kenia Esmeralda Ramos Javier
 * Updated: Editorial Finance; resumen de solicitud, liquidación y comprobantes sin recarga total (ReceiptItem opcional en main).
 */
export const prerender = false;
import MainLayout from "@layouts/MainLayout.astro";
import EditorialHeader from "@components/EditorialHeader.astro";
import RequestDetail from "@components/RequestDetail.astro";
import RequestExpensesValidationSection from "@components/RequestExpensesValidationSection.astro";
import CommentsThread from "@components/comments/CommentsThread";
import type { UserRole } from "@type/roles";

import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";
import { apiRequest } from "@/utils/apiClient";

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const userName = getCookie("username", Astro.cookies) ?? "";
const buttonLabel = roleLabels[role];

const { id } = Astro.params;
const numericId = Number(id);
if (isNaN(numericId)) {
  throw new Error(`El ID debe ser numérico. Recibido: ${id}`);
}

let travelRequest = null;
try {
  travelRequest = await apiRequest(`/applicant/get-user-request/${id}`, { cookies: Astro.cookies });
} catch {
  travelRequest = null;
}

const currentUserId = getCookie("id", Astro.cookies);
const authToken = getCookie("token", Astro.cookies);
---

<MainLayout title={`Solicitud #${numericId}`} data={{ userName, buttonLabel, role }}>
  <main class="flex flex-col gap-8">
    <EditorialHeader
      eyebrow={`Coco / Comprobaciones / #${numericId}`}
      title={`Solicitud #${numericId}`}
      subtitle="Validación de comprobantes de gastos"
    >
      <a
        href={`/detalles-solicitud/${numericId}`}
        class="text-sm font-medium text-[var(--color-primary-600)] hover:underline whitespace-nowrap"
      >
        Ver detalle completo de la solicitud →
      </a>
    </EditorialHeader>

    {travelRequest && (
      <RequestDetail
        request={travelRequest}
        title={`SOLICITUD #${travelRequest.request_id}`}
        subtitle="Resumen del viaje"
        backHref="/comprobaciones"
        showTimeline={false}
        showComments={false}
      />
    )}

    <RequestExpensesValidationSection
      requestId={numericId}
      enableActions={true}
      showFinishButton={true}
    />

    <section class="card-editorial p-5 sm:p-6">
      <header class="mb-4">
        <p class="eyebrow">Comunicación</p>
        <h2 class="font-editorial text-xl font-normal text-[var(--color-ink)] mt-1">
          Comentarios de la solicitud
        </h2>
        <p class="text-sm text-[var(--color-ink-muted)] mt-1">
          Usa el chat para pedir aclaraciones al solicitante. Al rechazar un comprobante, el motivo se publica aquí automáticamente.
        </p>
      </header>
      <CommentsThread
        client:only="react"
        name={userName}
        requestId={numericId}
        currentUserId={currentUserId ? parseInt(String(currentUserId), 10) : 1}
        authToken={authToken ?? ""}
      />
    </section>
  </main>
</MainLayout>
