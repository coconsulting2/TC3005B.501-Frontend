---
/**
 * Author: Michael Devlyn
 * Updated: Editorial Finance design system
 *
 * Admin dashboard — user management with editorial table.
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MetricCard from "@components/MetricCard.astro";
import TableFallback from "@components/Table/TableFallback.astro";
import UltimateWrapper from "@components/UltimateWrapper";
import Button from "@components/Button.astro";

import type { UserRole } from "@type/roles";
import { getCookie } from "@data/cookies";
import { apiRequest } from "@/utils/apiClient";

interface User {
  user_id: number;
  user_name: string;
  email: string;
  role_name: string;
  department_name: string;
  organization_id?: string;
  organization_name?: string;
  active?: boolean;
}

var errorMessage = null;
const users = await (async () => {
  try {
    return await apiRequest(`/admin/get-user-list`, { cookies: Astro.cookies });
  } catch (error) {
    errorMessage = "Error al cargar los usuarios. Inténtalo de nuevo.";
    return [];
  }
})();

const userGroups: { orgLabel: string; users: User[] }[] = (() => {
  const m = new Map<string, User[]>();
  for (const u of users as User[]) {
    const key = (u.organization_name ?? "").trim() || "Sin organización";
    if (!m.has(key)) m.set(key, []);
    m.get(key)!.push(u);
  }
  return Array.from(m.entries())
    .sort((a, b) => a[0].localeCompare(b[0], "es", { sensitivity: "base" }))
    .map(([orgLabel, list]) => ({ orgLabel, users: list }));
})();

const role: UserRole = getCookie("role", Astro.cookies) as UserRole;
const userName = getCookie("username", Astro.cookies);

const roleVariant: Record<string, string> = {
  'Administrador': 'bg-primary-50 text-primary-500',
  'N1': 'bg-success-50 text-success-500',
  'N2': 'bg-success-50 text-success-500',
  'Solicitante': 'bg-[var(--color-surface-secondary)] text-[var(--color-ink-secondary)]',
  'Agencia de viajes': 'bg-warning-50 text-warning-500',
  'Cuentas por pagar': 'bg-accent-50 text-accent-400',
};
---

<div>
  {errorMessage ? (
    <div class="card-editorial border-accent-400 p-4 mb-6">
      <p class="text-sm text-accent-400">{errorMessage}</p>
    </div>
  ) : null}

  {users && users.length === 0 && !errorMessage ? (
    <TableFallback />
  ) : users.length > 0 ? (
    <>
      <EditorialHeader
        eyebrow="Coco / Administración"
        title="Usuarios del sistema"
        subtitle={`${users.length} usuarios en ${userGroups.length} organización(es)`}
      >
        <a href="/crear-usuario">
          <Button variant="filled" color="primary" size="medium">
            + Crear usuario
          </Button>
        </a>
      </EditorialHeader>

      <!-- Metrics -->
      <div class="flex mb-8">
        <MetricCard
          label="Total usuarios"
          value={String(users.length)}
          position="first"
        />
        <MetricCard
          label="Roles activos"
          value={String(new Set(users.map((u: User) => u.role_name)).size)}
          position="middle"
        />
        <MetricCard
          label="Organizaciones (vista)"
          value={String(userGroups.length)}
          position="last"
        />
      </div>

      <!-- Users table — editorial style -->
      <section class="card-editorial overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr class="border-b border-[var(--color-neutral-200)]">
                <th class="px-6 py-3 text-left eyebrow">ID</th>
                <th class="px-6 py-3 text-left eyebrow">Usuario</th>
                <th class="px-6 py-3 text-left eyebrow">Email</th>
                <th class="px-6 py-3 text-left eyebrow">Rol</th>
                <th class="px-6 py-3 text-left eyebrow">Departamento</th>
                <th class="px-6 py-3 text-center eyebrow">Acciones</th>
              </tr>
            </thead>
            <tbody>
              {userGroups.map((group) => (
                <>
                  <tr class="bg-[var(--color-surface-tertiary)] border-b border-[var(--color-neutral-200)]">
                    <td colspan={6} class="px-6 py-2 text-xs font-semibold uppercase tracking-wide text-[var(--color-ink-secondary)]">
                      {group.orgLabel}
                      <span class="normal-case font-normal text-[var(--color-ink-muted)]">
                        {" "}— {group.users.length === 1 ? "1 usuario" : `${group.users.length} usuarios`}
                      </span>
                    </td>
                  </tr>
                  {group.users.map((user: User, index: number) => {
                    const isLastInGroup = index === group.users.length - 1;
                    return (
                  <tr class={`${!isLastInGroup ? 'border-b border-[var(--color-neutral-200)]' : ''} hover:bg-[var(--color-surface-secondary)] transition-colors`}>
                    <td class="px-6 py-4 text-sm text-[var(--color-ink-muted)] tabular-nums">{user.user_id}</td>
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-[var(--color-neutral-200)] text-[var(--color-ink-secondary)] flex-shrink-0">
                          <span class="text-xs font-semibold">
                            {user.user_name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()}
                          </span>
                        </div>
                        <span class="text-sm font-medium text-[var(--color-ink)]">{user.user_name}</span>
                      </div>
                    </td>
                    <td class="px-6 py-4 text-sm text-[var(--color-ink-secondary)]">{user.email}</td>
                    <td class="px-6 py-4">
                      <span class={`status-pill ${roleVariant[user.role_name] || 'bg-[var(--color-surface-secondary)] text-[var(--color-ink-secondary)]'}`}>
                        {user.role_name}
                      </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-[var(--color-ink-secondary)]">{user.department_name || '—'}</td>
                    <td class="px-6 py-4 text-center">
                      <div class="flex items-center justify-center gap-2">
                        <a href={`/editar-usuario/${user.user_id}`}>
                          <button class="text-sm text-blue-600 hover:text-blue-500 transition-colors font-medium cursor-pointer">
                            Editar
                          </button>
                        </a>
                        <UltimateWrapper
                          client:only="react"
                          user_id={user.user_id}
                          endpoint="/admin/delete-user"
                          title="Eliminar usuario"
                          message={`¿Estás seguro de que deseas eliminar al usuario ${user.user_name}? Esta acción no se puede deshacer.`}
                          modal_type="warning"
                          token={getCookie("token", Astro.cookies)}
                          buttonClassName="text-sm text-error-500 hover:text-error-400 transition-colors font-medium cursor-pointer"
                        >
                          Eliminar
                        </UltimateWrapper>
                      </div>
                    </td>
                  </tr>
                    );
                  })}
                </>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </>
  ) : null}
</div>
