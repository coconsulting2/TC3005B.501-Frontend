---
/**
 * Authors: Eduardo Porto Morales
 * Updated: Editorial Finance design system
 *
 * Cuentas por pagar — "Revisión financiera" editorial view.
 */

import EditorialHeader from "@components/EditorialHeader.astro";
import MetricCard from "@components/MetricCard.astro";
import RequestSection from "@components/RequestSection.astro";

import { getCookie } from "@data/cookies";
import { apiRequest } from '@utils/apiClient';

const department = getCookie("department_id", Astro.cookies);

const requestsInCotizar = await (async () => {
  try {
    return await apiRequest(`/user/get-travel-requests/${department}/4`, { cookies: Astro.cookies });
  } catch (error) {
    return [];
  }
})();

const requestsInComprobar = await (async () => {
  try {
    return await apiRequest(`/user/get-travel-requests/${department}/7`, { cookies: Astro.cookies });
  } catch (error) {
    return [];
  }
})();

const { userName } = Astro.props;
const totalPending = requestsInCotizar.length + requestsInComprobar.length;
---

<div>
  <main>
    <EditorialHeader
      eyebrow="Coco / Aprobaciones / Finanzas"
      title="Revisión financiera"
      subtitle={`${userName} &middot; Cuentas por pagar`}
    />

    <!-- Metrics -->
    <div class="flex mb-8">
      <MetricCard
        label="Por cotizar"
        value={String(requestsInCotizar.length)}
        position="first"
      />
      <MetricCard
        label="Por comprobar"
        value={String(requestsInComprobar.length)}
        position="middle"
      />
      <MetricCard
        label="Total pendientes"
        value={String(totalPending)}
        position="last"
      />
    </div>

    <!-- Sections -->
    <div class="grid grid-cols-1 gap-6">
      <RequestSection
        title="Solicitudes por cotizar"
        requests={requestsInCotizar}
        anchor="cotizaciones"
        urlBase="cotizar-solicitud"
        subtitle="Pendiente de cotización"
        emptyMessage="No hay solicitudes por cotizar"
      />

      <RequestSection
        title="Solicitudes por comprobar"
        requests={requestsInComprobar}
        anchor="comprobaciones"
        urlBase="comprobar-gastos"
        subtitle="Pendiente de comprobación"
        emptyMessage="No hay solicitudes por comprobar"
      />
    </div>
  </main>
</div>
