---
/**
 * Authors: Gabriel Munoz, Jose Gonzalez
 * Updated: Editorial Finance design system
 *
 * Solicitante dashboard — "Mis pendientes" editorial view.
 */

import MaterialIcon from "@components/MaterialIcon.astro";
import EditorialHeader from "@components/EditorialHeader.astro";
import MetricCard from "@components/MetricCard.astro";
import Button from "@components/Button.astro";
import CancelRequestModal from "@components/CancelRequestModal.tsx";

import { getCookie } from "@data/cookies";
import { apiRequest } from '@utils/apiClient';

const statusMap: { [key: string]: string } = {
  'Primera Revisión': "status-pill--review",
  'Segunda Revisión': "status-pill--review",
  'Cotización del Viaje': "status-pill--pending",
  'Atención Agencia de Viajes': "status-pill--pending",
  'Comprobación gastos del viaje': "status-pill--review",
  'Validación de comprobantes': "status-pill--review",
};

const user_id = getCookie("id", Astro.cookies);

const requests = await (async () => {
  try {
    try {
      const allRequests = await apiRequest(`/applicant/get-user-requests/${user_id}`, {
        cookies: Astro.cookies
      });
      return allRequests.filter((request: any) => request.status !== "Borrador");
    } catch (apiError) {
      console.error("Error fetching requests:", apiError);
      return [];
    }
  } catch (error) {
    console.error("Error in request handling:", error);
    return [];
  }
})();

const { userName } = Astro.props;

const inReview = requests.filter((r: any) =>
  ['Primera Revisión', 'Segunda Revisión'].includes(r.status)
).length;
const pending = requests.filter((r: any) =>
  ['Cotización del Viaje', 'Atención Agencia de Viajes'].includes(r.status)
).length;
const toVerify = requests.filter((r: any) =>
  ['Comprobación gastos del viaje', 'Validación de comprobantes'].includes(r.status)
).length;
---

<div>
  <main>
    <EditorialHeader
      eyebrow="Coco / Mis solicitudes"
      title={`Buenas tardes, ${userName}`}
      subtitle={`Tienes ${requests.length} solicitudes activas`}
    >
      <a href="/crear-solicitud">
        <Button variant="filled" color="primary" size="medium">
          + Nueva solicitud
        </Button>
      </a>
    </EditorialHeader>

    <!-- Metric cards joined -->
    <div class="flex mb-8">
      <MetricCard
        label="En revisión"
        value={String(inReview)}
        position="first"
      />
      <MetricCard
        label="Por comprobar"
        value={String(toVerify)}
        position="middle"
      />
      <MetricCard
        label="En proceso"
        value={String(pending)}
        position="last"
      />
    </div>

    <!-- Requests requiring attention -->
    {requests.length > 0 && (
      <section class="card-editorial">
        <div class="px-6 py-4 border-b border-[var(--color-neutral-200)]">
          <h2 class="font-editorial text-lg font-normal text-[var(--color-ink)]">
            Requieren tu atención
          </h2>
        </div>

        {requests.map((request: any, index: number) => {
          const isEditable = request.status === "Primera Revisión";
          const isNotCancelable = request.status === "Comprobación gastos del viaje" || request.status === "Validación de comprobantes";
          /** Comprobantes/gastos: tras N2 (cotización en adelante hasta validación). */
          const canOpenComprobaciones = [
            "Cotización del Viaje",
            "Atención Agencia de Viajes",
            "Comprobación gastos del viaje",
            "Validación de comprobantes",
          ].includes(request.status);
          const isLast = index === requests.length - 1;

          return (
            <div class={`px-6 py-4 flex items-center justify-between gap-6 ${!isLast ? 'border-b border-[var(--color-neutral-200)]' : ''} hover:bg-[var(--color-surface-secondary)] transition-colors`}>
              <!-- Left: Number + Info -->
              <div class="flex items-center gap-4 flex-1 min-w-0">
                <span class="font-editorial text-lg text-[var(--color-ink-muted)] tabular-nums w-6 text-right">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <a href={`/detalles-solicitud/${request.request_id}`} class="flex-1 min-w-0">
                  <p class="font-medium text-[var(--color-ink)] truncate">
                    {request.destination_country}
                  </p>
                  <p class="text-xs text-[var(--color-ink-muted)] mt-0.5">
                    #{request.request_id} &middot; {request.beginning_date} &ndash; {request.ending_date}
                  </p>
                </a>
              </div>

              <!-- Status pill -->
              <span class={`status-pill ${statusMap[request.status] || 'status-pill--review'}`}>
                {request.status}
              </span>

              <!-- Actions -->
              <div class="flex items-center gap-2">
                {isEditable && (
                  <a href={`/editar-solicitud/${request.request_id}`}>
                    <Button variant="border" color="primary" size="small">
                      Editar
                    </Button>
                  </a>
                )}
                {canOpenComprobaciones && (
                  <a href={`/comprobar-solicitud/${request.request_id}`}>
                    <Button variant="filled" color="primary" size="small">
                      Comprobar
                    </Button>
                  </a>
                )}
                {!isNotCancelable && (
                  <CancelRequestModal
                    client:only="react"
                    id={request.request_id}
                    disabled={isNotCancelable}
                    token={getCookie("token", Astro.cookies)}
                  >
                    <div class="p-1.5 rounded-[var(--radius-md)] text-[var(--color-ink-muted)] hover:bg-accent-50 hover:text-accent-400 transition-colors cursor-pointer">
                      <MaterialIcon icon="delete" color="currentColor" />
                    </div>
                  </CancelRequestModal>
                )}
              </div>
            </div>
          );
        })}
      </section>
    )}

    {requests.length === 0 && (
      <div class="card-editorial py-16 text-center">
        <p class="text-[var(--color-ink-muted)]">No tienes viajes agendados</p>
        <a href="/crear-solicitud" class="mt-4 inline-block">
          <Button variant="filled" color="primary" size="medium">
            Solicita tu primer viaje
          </Button>
        </a>
      </div>
    )}
  </main>
</div>
