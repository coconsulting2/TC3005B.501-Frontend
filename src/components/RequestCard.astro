---
/**
 * Author: Eduardo Porto Morales
 * Updated: Editorial Finance design system
 *
 * Card for displaying a travel request — 1px border, editorial typography.
 */

const { request, urlBase, subtitle } = Astro.props;
---

<a href={`/${urlBase}/${request.request_id}`} class="block">
  <div class="card-editorial p-5 transition-colors duration-150 hover:border-[var(--color-neutral-400)]">
    <div class="flex items-start justify-between mb-3">
      <div>
        <p class="font-medium text-[var(--color-ink)]">
          Viaje a {request.destination_country}
        </p>
        <p class="text-xs text-[var(--color-ink-muted)] mt-0.5">{subtitle}</p>
      </div>
      <span class="text-sm font-medium text-[var(--color-ink-muted)] font-editorial tabular-nums">
        #{request.request_id}
      </span>
    </div>

    <div class="separator my-3"></div>

    <div class="flex items-center justify-between text-sm">
      <div class="text-[var(--color-ink-secondary)]">
        <span class="text-[var(--color-ink-muted)]">Del</span> {request.beginning_date}
        <span class="text-[var(--color-ink-muted)] ml-1">al</span> {request.ending_date}
      </div>
      <span class="status-pill bg-[var(--color-surface-secondary)] text-[var(--color-ink-muted)]">
        {request.request_status}
      </span>
    </div>
  </div>
</a>
