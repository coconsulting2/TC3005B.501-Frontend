---
/**
 * Comprobantes de gastos con detalle CFDI/archivos y acciones CxP.
 * Usado en detalle de solicitud y en la pantalla dedicada de validación.
 */
import ReceiptActions from "@components/ReceiptActions";
import ReceiptDetailCard from "@components/ReceiptDetailCard";
import FinishRequestButton from "@components/FinisCheck.tsx";
import { getCookie } from "@data/cookies";
import { apiRequest } from "@/utils/apiClient";
import {
  enrichExpensesWithFiles,
  type ExpenseValidationApiRow,
} from "@/utils/receiptExpenseRows";

interface Props {
  requestId: number;
  /** Aprobar / rechazar comprobantes (estado 7). */
  enableActions?: boolean;
  /** Enlace a /comprobar-gastos/:id */
  showDedicatedLink?: boolean;
  /** Botón finalizar solicitud cuando todos revisados. */
  showFinishButton?: boolean;
}

const {
  requestId,
  enableActions = false,
  showDedicatedLink = false,
  showFinishButton = false,
} = Astro.props as Props;

const authToken = getCookie("token", Astro.cookies);

let expensePayload: {
  request_id: number;
  Expenses?: ExpenseValidationApiRow[];
} | null = null;

try {
  expensePayload = await apiRequest(
    `/accounts-payable/get-expense-validations/${requestId}`,
    { cookies: Astro.cookies },
  );
} catch {
  expensePayload = null;
}

const expenses = Array.isArray(expensePayload?.Expenses) ? expensePayload.Expenses : [];
const receiptRows = await enrichExpensesWithFiles(expenses, Astro.cookies);

const allReviewed =
  receiptRows.length > 0 &&
  receiptRows.every((r) => r.validation !== "Pendiente");
---

<section class="card-editorial overflow-hidden mt-8">
  <div class="px-6 py-4 border-b border-[var(--color-neutral-200)] flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="eyebrow">Comprobantes de gastos</p>
      <h2 class="font-editorial text-xl font-normal text-[var(--color-ink)] mt-1">
        Validación de comprobantes
      </h2>
      {enableActions && (
        <p class="text-sm text-[var(--color-ink-muted)] mt-1">
          Puedes aprobar o rechazar cada comprobante aquí. Al rechazar, el motivo se publica en el chat de la solicitud.
        </p>
      )}
    </div>
    <div class="flex flex-wrap items-center gap-3 shrink-0">
      {showFinishButton && allReviewed && expensePayload && (
        <FinishRequestButton
          client:only="react"
          requestId={expensePayload.request_id}
          token={authToken ?? ""}
        />
      )}
      {showDedicatedLink && (
        <a
          href={`/comprobar-gastos/${requestId}`}
          class="text-sm font-medium text-[var(--color-primary-600)] hover:underline"
        >
          Abrir pantalla de validación →
        </a>
      )}
    </div>
  </div>

  {!expensePayload ? (
    <div class="p-8 text-center">
      <p class="text-sm text-[var(--color-ink-muted)]">
        No se pudieron cargar los comprobantes de esta solicitud.
      </p>
    </div>
  ) : receiptRows.length === 0 ? (
    <div class="p-8 text-center">
      <p class="text-sm text-[var(--color-ink-muted)]">
        No hay comprobantes registrados para esta solicitud.
      </p>
    </div>
  ) : (
    <div>
      {receiptRows.map((receipt, index) => (
        <ReceiptDetailCard
          client:visible
          index={index}
          receiptId={receipt.receipt_id}
          receiptTypeName={receipt.receipt_type_name}
          amount={receipt.amount}
          validation={receipt.validation}
          cfdi={receipt.cfdi}
          pdf={receipt.pdf}
          xml={receipt.xml}
          receiptImage={receipt.receipt_image}
          apiBaseUrl={import.meta.env.PUBLIC_API_BASE_URL}
          isLast={index === receiptRows.length - 1}
        >
          {enableActions && expensePayload && (
            <div class="mt-3 ml-10 flex items-center gap-3">
              <ReceiptActions
                client:only="react"
                receipt_id={receipt.receipt_id}
                request_id={expensePayload.request_id}
                receipt_type_name={receipt.receipt_type_name}
                expense_status={receipt.expense_status}
                disabled={receipt.validation !== "Pendiente"}
                token={authToken ?? ""}
              />
            </div>
          )}
        </ReceiptDetailCard>
      ))}
    </div>
  )}
</section>
