---
/**
 * Author: Diego Ortega Fernandez
 * Updated: Editorial Finance design system
 */

interface Props {
  title?: string;
  message?: string;
  buttonText?: string;
  buttonLink?: string;
}

const {
  title = "Sin solicitudes pendientes",
  message = "Actualmente no hay información disponible para mostrar.",
  buttonText = "Regresar al dashboard",
  buttonLink = "/dashboard",
} = Astro.props;
---

<div style="display:flex; flex-grow:1; height:calc(100vh - 175px); align-items:center; justify-content:center; padding:1rem 1rem;">
  <div style="max-width:28rem; width:100%; background:white; border:1px solid #E8E7E2; border-radius:8px; padding:2.5rem; text-align:center;">
    <h1 style="font-family:'Fraunces',Georgia,serif; font-size:1.5rem; font-weight:400; color:#0A0A0A; margin:0 0 0.75rem 0;">
      {title}
    </h1>
    <p style="font-size:0.875rem; color:#8A8A86; margin:0 0 1.5rem 0;">
      {message}
    </p>
    <a
      href={buttonLink}
      style="display:inline-block; padding:0.625rem 1.5rem; font-size:0.875rem; font-weight:500; color:white; background:#3D4A2A; border-radius:6px; text-decoration:none; transition:background-color 0.2s;"
    >
      {buttonText}
    </a>
  </div>
</div>
