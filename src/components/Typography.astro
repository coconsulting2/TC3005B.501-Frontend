---
/**
 * Typography Component — Editorial Finance design system.
 * Uses Fraunces for headers, Inter for body.
 */

export interface Props {
  variant: 'header' | 'subHeader' | 'paragraph';
  size?: 'default' | 'small';
  class?: string;
}

const { variant, size = 'default', class: className = '' } = Astro.props;

let classes = '';

if (variant === 'header') {
  classes += 'font-editorial font-normal text-[var(--color-ink)] ';
  classes += size === 'default' ? 'text-3xl' : 'text-2xl';
} else if (variant === 'subHeader') {
  classes += 'font-editorial font-normal text-[var(--color-ink)] ';
  classes += size === 'default' ? 'text-xl' : 'text-lg';
} else if (variant === 'paragraph') {
  classes += 'text-[var(--color-ink-secondary)] ';
  classes += size === 'default' ? 'text-base' : 'text-sm';
}

if (className) {
  classes += ' ' + className;
}
---

<div class={classes}>
  <slot />
</div>
