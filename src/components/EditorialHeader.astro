---
/**
 * Editorial page header with eyebrow, serif title, and optional subtitle.
 * Replaces TextHeader with the "Editorial Finance" identity.
 *
 * @param eyebrow - Small caps label (e.g. "COCO / PANEL DE CONTROL")
 * @param title - Main heading in Fraunces serif
 * @param subtitle - Optional description line
 * @param rightSlot - Optional right-aligned content (buttons, filters)
 */

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<header class="mb-6 md:mb-8">
  {eyebrow && (
    <p class="eyebrow mb-2">{eyebrow}</p>
  )}
  <div class="flex flex-col gap-3 min-w-0 md:flex-row md:items-start md:justify-between md:gap-6">
    <div class="min-w-0 flex-1">
      <h1 class="font-editorial text-2xl font-normal leading-tight text-[var(--color-ink)] break-words sm:text-3xl">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-1 text-sm text-[var(--color-ink-muted)] break-words">{subtitle}</p>
      )}
    </div>
    <div class="flex shrink-0 flex-wrap items-center gap-2 md:justify-end md:gap-3">
      <slot />
    </div>
  </div>
</header>
