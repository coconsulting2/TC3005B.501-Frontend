---
/**
 * Author: Julia Maria Stephanie Duenkelsbuehler Castillo
 * Updated: Editorial Finance design system
 */

import Button from '@components/Button.astro';

const pageTitle = "Solicitud Creada";
---

<main class="p-12 min-h-screen" style="background-color: var(--color-surface);">
  <div class="max-w-xl mx-auto card-editorial p-10 text-center">
    <div class="mb-6">
      <svg class="mx-auto h-14 w-14 text-success-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="font-editorial text-2xl font-normal text-[var(--color-ink)] mb-3">
      Solicitud enviada
    </h1>

    <p class="text-sm text-[var(--color-ink-muted)] mb-8">
      Tu solicitud de viaje ha sido registrada correctamente.
    </p>

    <div class="flex justify-center">
      <a href="/dashboard">
        <Button
          variant="filled"
          color="primary"
          class="px-8"
        >
          Ir al dashboard
        </Button>
      </a>
    </div>
  </div>
</main>
