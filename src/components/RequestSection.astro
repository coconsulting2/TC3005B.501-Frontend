---
/**
 * Request section — editorial card container with header and list of request cards.
 */

import RequestCard from "@components/RequestCard.astro";

const {
  title,
  requests = [],
  anchor,
  urlBase,
  subtitle,
  emptyMessage = "No hay solicitudes disponibles"
} = Astro.props;
---

<section class="card-editorial p-6">
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-baseline gap-2">
      <h2 class="font-editorial text-xl font-normal text-[var(--color-ink)]">
        {title}
      </h2>
      <span class="text-sm text-[var(--color-ink-muted)] tabular-nums">
        ({requests.length})
      </span>
    </div>
    <a href={`/${anchor}`} class="text-sm text-primary-500 hover:text-primary-400 transition-colors">
      Ver todas &rarr;
    </a>
  </div>

  {requests.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {requests.slice(0, 4).map((request: any) => (
        <RequestCard
          request={request}
          urlBase={urlBase}
          subtitle={subtitle}
        />
      ))}
    </div>
  ) : (
    <div class="py-12 text-center">
      <p class="text-sm text-[var(--color-ink-muted)]">{emptyMessage}</p>
    </div>
  )}
</section>
