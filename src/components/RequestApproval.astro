---
/**
 * Author: Julia Maria Stephanie Duenkelsbuehler Castillo Y Nicole Davila
 *
 * Description: Detalle de solicitud para autorización; botones solo si hay permiso travel_request:authorize.
 */

import { getCookie } from '@/data/cookies';
import RequestDetail from '@components/RequestDetail.astro';
import TravelRequestAuthorizeActions from '@components/TravelRequestAuthorizeActions.tsx';

interface Props {
  request: Record<string, unknown> & { request_id: number };
  canAuthorize: boolean;
}

const { request, canAuthorize } = Astro.props;
const id = request.request_id;
---
<main class="flex flex-col">
  <div>
    <RequestDetail
      request={request}
      title={`SOLICITUD #${request.request_id}`}
      subtitle="Detalles de la solicitud"
    />
    {canAuthorize ? (
      <TravelRequestAuthorizeActions
        client:only="react"
        request_id={id}
        token={getCookie("token", Astro.cookies)}
      />
    ) : (
      <p class="mt-8 text-sm text-[var(--color-ink-secondary)] max-w-xl">
        Tu rol solo permite revisar esta solicitud; no tienes permiso para aprobar, rechazar o reasignar.
      </p>
    )}
  </div>
</main>
