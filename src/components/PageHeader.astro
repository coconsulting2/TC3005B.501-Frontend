---
/**
 * Author: Julia Maria Stephanie Duenkelsbuehler Castillo
 * Updated: Editorial Finance design system
 *
 * Top navigation bar — clean, minimal, 1px bottom border.
 */

const { userName, buttonLabel } = Astro.props;
import LogoutButton from "@components/Logout.tsx";
import MaterialIcon from "@components/MaterialIcon.astro";

const isCurrentRoute = Astro.url.pathname === "/perfil-usuario";
---

<header class="flex justify-between items-center bg-[var(--color-surface-white)] border-b border-[var(--color-neutral-200)] px-6 h-14">
  <!-- Left: Logo + Brand -->
  <div class="flex items-center gap-3">
    <a href="/dashboard" class="flex items-center gap-2.5">
      <img
        src="/Logo.svg"
        class="w-9 h-9"
        alt="CocoAPI"
      />
      <span class="eyebrow text-[var(--color-ink)] tracking-widest font-semibold">COCOAPI</span>
    </a>
  </div>

  <!-- Right: Role + Actions + User -->
  <div class="flex items-center gap-3">
    <!-- User Role Badge -->
    <span class="status-pill bg-[var(--color-surface-secondary)] text-[var(--color-ink-secondary)] border border-[var(--color-neutral-200)]">
      {buttonLabel}
    </span>

    <!-- Actions -->
    <div class="flex items-center gap-1">
      <LogoutButton client:load>
        <div class="p-2 rounded-[var(--radius-md)] text-[var(--color-ink-muted)] hover:bg-[var(--color-surface-secondary)] hover:text-[var(--color-ink)] transition-colors cursor-pointer">
          <MaterialIcon icon="logout" color="currentColor" />
        </div>
      </LogoutButton>
    </div>

    <!-- User Info -->
    <div class="flex items-center gap-3 pl-2 border-l border-[var(--color-neutral-200)]">
      <span class="text-sm font-medium text-[var(--color-ink)]">
        {userName}
      </span>
      <a href="/perfil-usuario" class={isCurrentRoute ? "pointer-events-none" : ""}>
        <div
          class="flex items-center justify-center rounded-full w-9 h-9 bg-primary-500 text-white cursor-pointer transition-all duration-200 hover:bg-primary-400"
        >
          <span class="text-xs font-semibold">
            {userName.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase()}
          </span>
        </div>
      </a>
    </div>
  </div>
</header>
