---
/**
 * Component: SidebarButton
 * Description: Sidebar nav link — editorial style with subtle backgrounds.
 * Author: Kenia Ramos.
 **/

import type { MenuItem } from "@type/menu-config";
import MaterialIcon from "@components/MaterialIcon.astro";

interface Props {
  item: MenuItem;
  isActive: boolean;
}

const { item, isActive } = Astro.props;
---

<a
  href={item.route}
  class={`flex items-center gap-3 px-3 py-2.5 rounded-[var(--radius-md)] transition-colors duration-150 group
    ${isActive
      ? 'bg-primary-50 text-primary-500 pointer-events-none font-medium'
      : 'text-[var(--color-ink-secondary)] hover:bg-[var(--color-surface-secondary)] hover:text-[var(--color-ink)]'}
  `}
>
  <span class="flex items-center justify-center w-5 h-5">
    <MaterialIcon
      icon={item.icon}
      color={isActive ? 'var(--color-primary-500)' : 'currentColor'}
    />
  </span>
  <span class="truncate text-sm">{item.label}</span>
</a>
