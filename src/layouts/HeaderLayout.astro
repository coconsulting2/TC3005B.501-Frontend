---
import "@styles/global.css"
import PageHeader from "@components/PageHeader.astro"

interface Props {
  title: string;
  data: {
    userName: string;
    buttonLabel: string;
  };
}

const { title, data } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="description" content="CocoAPI — Sistema de gestión de viajes" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Editorial fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-[var(--color-surface)]">
    <div id="app">
      <header id="page-header">
        <PageHeader userName={data.userName} buttonLabel={data.buttonLabel} />
      </header>

      <section id="content">
        <div class="flex flex-col px-10 py-8 h-full max-w-[1200px] mx-auto">
          <slot />
        </div>
      </section>
    </div>

    <style>
      #app {
        display: grid;
        grid-template-areas:
          "header"
          "content";
        grid-template-rows: auto 1fr;
        height: 100vh;
      }

      #page-header {
        grid-area: header;
      }

      #content {
        grid-area: content;
        height: 100%;
        overflow-y: auto;
        background: var(--color-surface);
      }
    </style>
  </body>
</html>
